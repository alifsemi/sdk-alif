source "Kconfig.zephyr"

config USE_APP_MENU
	bool "Use application menu to choose a test case"
	default false

config ACTIVATION_BUF_SECTION
	string "Linker section where activation buffer (tensor arena) is placed"
	default ".bss.activation_buf"

config ACTIVATION_BUF_SZ
	hex "Tensor arena size"
	default 0x00091000

config MODEL_IN_EXT_FLASH
	bool "Put ML model to external flash"
	select FLASH
	select ALIF_OSPI_FLASH_XIP
	help
		Initialize OSPI controller to XIP mode. Initialize the onboard flash device. Link ML model data to external flash address space.
		In addition to normal zephyr.bin output, ospi0/1.bin is generated. When enabled, the model memory section is set automatically (See BufAttributes.h)

config MODEL_SECTION
	string "Linker section where ML model is placed"
	depends on !MODEL_IN_EXT_FLASH
	default ".rodata.tflm_model"

config ETHOS_U_AXI0_ONLY
	bool "Only use AXI0 port on the Ethos"
	default false

config AUDIO_SAMPLES
	int "Number of audio samples to store"
	default 16000

config AUDIO_STRIDE
	int "Number of audio samples in a single stride"
	default 8000

config RESULTS_MEMORY
	int "Number of inference results to keep in memory"
	default 8

config AUDIO_CHANNELS
	int "Number of input audio channels"
	default 2

config SAMPLE_CNT
	int "Number of samples per slab buffer"
	default 400

config NUM_BUFFERS
	int "Number of slab buffers to allocate"
	default 4

config I2S_GAIN
	int "Fixed linear again applied to I2S samples (e.g 10 = 20dB gain)"
	default 20

config THREAD_STACK_SIZE
	int "Stack size of audio thread"
	default 1024

config THREAD_PRIORITY
	int "Priority of audio thread"
	default 0

config PUSH_TO_TALK
	bool "Use push to talk power example"
	default false

config OUTPUT_TO_LINE_OUT
	depends on I2S
	bool "Output audio to line out"
	default false

config LPGPIO_WAKEUP_SOURCE
	depends on "$(dt_nodelabel_enabled,lpgpio)"
	int "LPGPIO Wakeup source will be used to wakeup from sleep"
	range 0 4
	default 1
	help
	  Defines which LPGPIO pin will be used as wakeup source from sleep.
	  0 - LPGPIO0, 1 - LPGPIO1, ...

config LPGPIO_M55_IRQ_ENABLED
	depends on "$(dt_nodelabel_enabled,lpgpio)"
	bool "LPGPIO M55 core IRQ enabled"
	default y
	help
	  Configures LPGPIO to generate interrupt on M55 core when M55 is
	  running.

choice
	depends on LPGPIO_M55_IRQ_ENABLED
	prompt "LPGPIO IRQ edge trigger select"
	default LPGPIO_M55_IRQ_EDGE_FALLING
	help
	  Select which signal edge will trigger the interrupt.
	config LPGPIO_M55_IRQ_EDGE_RISING
	bool "Rising edge"
	config LPGPIO_M55_IRQ_EDGE_FALLING
	bool "Falling edge"
	config LPGPIO_M55_IRQ_EDGE_BOTH
	bool "Rising and falling edges"
endchoice
