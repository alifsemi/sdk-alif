mainmenu "AIPL Benchmark sample configuration"

config AIPL_PREBUILT
    bool "Use a pre-built AIPL binary"
    depends on !AIPL
    default false
    help
        Use a pre-built AIPL binary instead of building it with Zephyr.
        CONFIG_AIPL should be set to false.

source "Kconfig.zephyr"