def samples1 = [
    'echo_client' : 'zephyr/samples/net/sockets',
    'echo_server' : 'zephyr/samples/net/sockets'
]

def generate_ble_stage(sampleName, samplePath) {
    return {
        stage("Build ${sampleName}") {
            script {
                def ble = load 'automation/ble_test.groovy'
                ble.buildSample(sampleName, samplePath)
            }
        }
    }
}


def bleStagesMap1 = samples1.collectEntries { name, path ->
    [(name): generate_ble_stage(name, path)]
}

pipeline {
    agent none

    options {
        disableConcurrentBuilds(abortPrevious: true)
        timeout(time: 2, unit: 'HOURS')
        timestamps()
    }

    stages {

        stage('Checkout') {
            agent { label 'zas20' }
            steps {
                checkout scm
            }
        }
        stage('BLE samples stage 1') {
            agent { label 'zas20' }
            steps {
                script {
                    parallel bleStagesMap1
                }
            }
        }
    }
}
