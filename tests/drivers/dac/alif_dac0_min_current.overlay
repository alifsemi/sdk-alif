/ {
	aliases {
		dac = &dac0;
	};
};

&dac0 {
	status = "okay";
	/* Two's complement mode disabled (property omitted) */
	/* Load capacitance compensation: 4pF */
	capacitance = "DAC_4PF_CAPACITANCE";
	/* Output current: MINIMUM 0 uA - for light load testing */
	output_current = "DAC_0UA_OUT_CUR";
};
