/ {
	aliases {
		dac = &dac1;
	};
};

&dac1 {
	status = "okay";
	/* Load capacitance compensation: 4pF */
	capacitance = "DAC_4PF_CAPACITANCE";
	/* Output current: 800 uA */
	output_current = "DAC_800UA_OUT_CUR";
};
