/ {
	aliases {
		gpioport = &timer_g1;
	};

	gpio {
		compatible = "gpio-leds";
		timer_g1: gpio_1 {
			gpios = <&gpio6 4 0>;
		};
	};
};
/*
 * Enabling lptimer & disabling rtc for this sample application
 * 10Khz -->10000
 */

&timer3 {
	clocks = <&clockctrl ALIF_LPTIMER3_LPTMR3_IO_PIN >;
	status = "okay";
};

&rtc0 {
	status = "disabled";
};
